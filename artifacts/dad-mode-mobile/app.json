{
  "expo": {
    "name": "Dad Mode",
    "slug": "dad-mode-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "dadmode",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d1829"
    },
    "ios": {
      "bundleIdentifier": "com.imperialmarketing.dados",
      "supportsTablet": false,
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to capture photos for memory journal entries.",
        "NSPhotoLibraryUsageDescription": "Used to attach photos to memory journal entries.",
        "NSPhotoLibraryAddUsageDescription": "Used to save photos from memory journal entries."
      }
    },
    "android": {
      "package": "com.imperialmarketing.dados",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0d1829"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "backgroundColor": "#0d1829"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://fatherhood-os.replit.app/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true,
          "faceIDPermission": "Allow Dad Mode to use Face ID."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    }
  }
}
